APP_ENV=local

FRONTEND_PORT=3000
BACKEND_PORT=8000
GRAPH_RUNTIME_PORT=8001
AGENTS_PORT=8002

API_BASE_URL=http://localhost:8000
GRAPH_RUNTIME_URL=http://localhost:8001
AGENTS_SERVICE_URL=http://localhost:8002

# Placeholder URLs
CHECKPOINT_STORE_URL=postgresql://user:pass@localhost:5432/pmo_ai
AUDIT_STORE_URL=postgresql://user:pass@localhost:5432/pmo_ai_audit

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Internal Services
RETRIEVAL_SERVICE_URL=http://localhost:8010
RULES_SERVICE_URL=http://localhost:8011
APPROVAL_SERVICE_URL=http://localhost:8012
AUDIT_SERVICE_URL=http://localhost:8013

# Auth & Governance
AUTH_MODE=local-dev
JWT_SECRET=change-me
TENANT_ID=local-tenant

LOG_LEVEL=INFO
ENABLE_MOCK_SERVICES=true
